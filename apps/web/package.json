{
  "name": "@inseason/web",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build": "uni build -p h5",
    "build:h5": "uni build -p h5",
    "build:mp-weixin": "uni build -p mp-weixin",
    "preview": "vite preview --host 0.0.0.0",
    "test:h5": "playwright test -c playwright.config.js",
    "test:mp-weixin": "cross-env VITE_TEST_FIXTURES=true UNI_PLATFORM=mp-weixin jest -i -c jest.config.cjs",
    "test:mp-weixin:prod": "cross-env UNI_PLATFORM=mp-weixin jest -i -c jest.config.cjs"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5010220260604001",
    "@vue/shared": "3.4.21",
    "vite": "5.2.8",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/uni-automator": "^3.0.0-alpha-5010220260604001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5010220260604001",
    "@playwright/test": "^1.60.0",
    "cross-env": "^7.0.3",
    "jest": "^27.0.4",
    "jest-environment-node": "^27.5.1"
  }
}
