<view class="page">
  <view class="content">
    <block wx:if="{{activeTab === 'season'}}">
      <view class="search">
        <text class="search__icon">⌕</text>
        <input value="{{query}}" placeholder="搜索当季果蔬" bindinput="onSearch" />
      </view>

      <view class="category-tabs">
        <button
          wx:for="{{categories}}"
          wx:key="value"
          class="category-tabs__button {{activeCategory === item.value ? 'active' : ''}} category-tabs__button--{{item.value}}"
          data-value="{{item.value}}"
          bindtap="selectCategory"
        >
          {{item.label}}
        </button>
      </view>

      <picker mode="selector" range="{{monthOptions}}" value="{{activeMonthIndex}}" bindchange="onMonthChange">
        <view class="filter-pill">{{monthOptions[activeMonthIndex]}}</view>
      </picker>

      <view class="season-card">
        <text class="season-card__label">当季</text>
        <view>
          <text class="season-card__title">{{heroTitle}}</text>
          <text class="season-card__copy">{{heroCount}} 样食材正值赏味期</text>
        </view>
      </view>

      <view class="grid">
        <button wx:for="{{visibleItems}}" wx:key="slug" class="produce-card {{item.category}}" data-slug="{{item.slug}}" bindtap="openDetail">
          <view class="produce-card__badge">{{item.badge}}</view>
          <view class="produce-card__body">
            <text class="produce-card__name">{{item.name}}</text>
            <text class="produce-card__meta">{{item.seasonLabel}}</text>
            <text class="produce-card__tag">{{item.reason}}</text>
          </view>
        </button>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'category'}}">
      <view class="page-title">
        <text class="page-title__icon">▦</text>
        <text>食材分类</text>
      </view>
      <view class="category-tabs">
        <button
          wx:for="{{categories}}"
          wx:key="value"
          class="category-tabs__button {{activeCategory === item.value ? 'active' : ''}} category-tabs__button--{{item.value}}"
          data-value="{{item.value}}"
          bindtap="selectCategory"
        >
          {{item.label}}
        </button>
      </view>
      <view class="group-list">
        <view wx:for="{{categoryGroups}}" wx:key="key" class="group-card">
          <view class="group-card__head">
            <text>{{item.label}}</text>
            <text>{{item.inSeasonCount}}/{{item.count}}</text>
          </view>
          <view class="group-card__items">
            <text wx:for="{{item.preview}}" wx:key="slug" class="group-card__item">{{item.name}}</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:elif="{{activeTab === 'origin'}}">
      <view class="page-title">
        <text class="page-title__icon">▱</text>
        <text>产地地图</text>
        <picker class="province-picker" mode="selector" range="{{provinceOptions}}" value="{{activeProvinceIndex}}" bindchange="onProvinceChange">
          <view class="province-picker__value">{{provinceOptions[activeProvinceIndex]}}⌄</view>
        </picker>
      </view>
      <view class="origin-panel">
        <text class="origin-panel__map">中国蔬果产地</text>
        <text class="origin-panel__hint">小程序包先展示产地数据，地图交互可接入腾讯地图组件继续增强</text>
      </view>
      <view class="province-card">
        <view class="province-card__head">
          <view>
            <text class="province-card__title">{{provinceProfile.province}}</text>
            <text class="province-card__meta">{{provinceProfile.count}} 种代表蔬果</text>
          </view>
          <text class="province-card__note">{{provinceProfile.note}}</text>
        </view>
        <view class="province-card__items">
          <button wx:for="{{provinceProfile.items}}" wx:key="name" class="province-card__item {{item.category}}" data-slug="{{item.slug}}" bindtap="openDetail">
            <text class="produce-card__badge">{{item.badge}}</text>
            <text>{{item.name}}</text>
          </button>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="page-title">
        <text class="page-title__icon">▥</text>
        <text>营养成份排行</text>
      </view>
      <view class="ranking-category">
        <button class="{{activeRankingCategory === 'fruit' ? 'active fruit' : 'fruit'}}" data-value="fruit" bindtap="selectRankingCategory">苹果 水果</button>
        <button class="{{activeRankingCategory === 'vegetable' ? 'active vegetable' : 'vegetable'}}" data-value="vegetable" bindtap="selectRankingCategory">青菜 蔬菜</button>
      </view>
      <view class="nutrient-tabs">
        <button
          wx:for="{{nutrients}}"
          wx:key="key"
          class="nutrient-tabs__button {{activeNutrient === item.key ? 'active' : ''}} nutrient-tabs__button--{{item.key}}"
          data-value="{{item.key}}"
          bindtap="selectNutrient"
        >
          {{item.label}}
        </button>
      </view>
      <view class="ranking-list">
        <button wx:for="{{rankingItems}}" wx:key="slug" class="ranking-row" data-slug="{{item.slug}}" bindtap="openDetail">
          <text class="ranking-row__rank ranking-row__rank--{{item.rank}}">{{item.rankIcon}}</text>
          <view>
            <text class="ranking-row__name">{{item.name}}</text>
            <text class="ranking-row__meta">{{item.subCategoryLabel}}</text>
          </view>
          <text class="ranking-row__value">{{item.nutrientValue}}</text>
        </button>
      </view>
    </block>
  </view>

  <view class="tabbar">
    <button
      wx:for="{{tabs}}"
      wx:key="value"
      class="tabbar__button {{activeTab === item.value ? 'active' : ''}}"
      data-value="{{item.value}}"
      bindtap="switchTab"
    >
      <text class="tabbar__icon">{{item.icon}}</text>
      <text>{{item.label}}</text>
    </button>
  </view>

  <view wx:if="{{selectedDetail}}" class="detail-mask" bindtap="closeDetail">
    <view class="detail-sheet" catchtap="noop">
      <view class="detail-sheet__head">
        <view>
          <text class="detail-sheet__title">{{selectedDetail.name}}</text>
          <text class="detail-sheet__meta">{{selectedDetail.subCategoryLabel}} · {{selectedDetail.seasonLabel}}</text>
        </view>
        <button bindtap="closeDetail">×</button>
      </view>
      <view class="detail-sheet__tags">
        <text wx:for="{{selectedDetail.benefitTags}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="detail-sheet__section">怎么吃</text>
      <text class="detail-sheet__copy">{{selectedDetail.bestUse}}</text>
      <text class="detail-sheet__section">怎么选</text>
      <text class="detail-sheet__copy">{{selectedDetail.selectionTips}}</text>
    </view>
  </view>
</view>
